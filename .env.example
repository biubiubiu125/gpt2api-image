# gpt2api-image deployment example

# Required admin key. Fill with a long random value before starting.
GPT2API_IMAGE_AUTH_KEY=

# Optional internal key for API <-> register-executor calls.
# Leave empty to reuse GPT2API_IMAGE_AUTH_KEY for the internal bridge.
GPT2API_IMAGE_REGISTER_INTERNAL_KEY=

# Public base URL used in returned image URLs.
GPT2API_IMAGE_BASE_URL=

# Postgres password used by docker-compose.yml.
POSTGRES_PASSWORD=

# API/worker image name used by docker-compose.yml.
GPT2API_IMAGE_IMAGE=gpt2api-image:local
GPT2API_IMAGE_REGISTER_EXECUTOR_IMAGE=gpt2api-image-register-executor:local

# Worker concurrency. Increase only when account pool and upstream stability allow it.
GPT2API_IMAGE_WORKER_CONCURRENCY=4

# Worker checks DB task cancellation at this interval.
GPT2API_IMAGE_WORKER_HEARTBEAT_INTERVAL_SECS=5

# PostgreSQL connection pool per API/worker process.
GPT2API_IMAGE_DB_MAX_OPEN_CONNS=20
GPT2API_IMAGE_DB_MAX_IDLE_CONNS=10

# Upstream transport: tls-client or curl-impersonate.
GPT2API_IMAGE_UPSTREAM_TRANSPORT=tls-client
GPT2API_IMAGE_CURL_IMPERSONATE_AUTO_DOWNLOAD=1

# Image route strategy: web_first, web_only, codex_first, or codex_only.
# Downstream image requests are always normalized to gpt-image-2; this only controls the internal route.
GPT2API_IMAGE_ROUTE_STRATEGY=web_first

# Optional CORS origins. Empty means same-origin only; use comma-separated origins when needed.
# GPT2API_IMAGE_CORS_ALLOWED_ORIGINS=https://your-web.example

# Optional request prompt logging. Keep disabled unless actively debugging.
GPT2API_IMAGE_LOG_REQUEST_TEXT=0

# Optional frontend build API URL. Leave empty when the web UI is served by the same API service.
# NEXT_PUBLIC_API_URL=
# NEXT_PUBLIC_DEV_BACKEND=http://127.0.0.1:8000

# Optional timezone.
TZ=Asia/Shanghai
